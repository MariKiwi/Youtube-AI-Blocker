COMPOSE_PROJECT_NAME=youtube-ai-blocker

API_IMAGE_NAME=youtube-ai-blocker-api
API_IMAGE_TAG=latest
API_PORT=3000

POSTGRES_DB=youtube_ai_blocker
POSTGRES_USER=youtube_ai_blocker
POSTGRES_PASSWORD=youtube_ai_blocker
POSTGRES_PORT=5432
POSTGRES_VOLUME_NAME=youtube-ai-blocker-postgres-data

BACKUP_DIR=./backups

CORS_ALLOWED_ORIGINS=https://www.youtube.com
WRITE_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX_REQUESTS=30
