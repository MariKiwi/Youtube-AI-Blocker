COMPOSE_PROJECT_NAME=youtube-ai-blocker

PUBLIC_WEBSITE_URL=https://your-website.example
PUBLIC_API_BASE_URL=https://api.your-website.example
EXTENSION_DEFAULT_API_BASE_URL=https://api.your-website.example
EXTENSION_VERSION=0.1.0
EXTENSION_DEFAULT_BLOCKING_ENABLED=false
EXTENSION_DEFAULT_DEBUG_UNKNOWN_INDICATORS=false
CHROME_WEB_STORE_URL=https://chromewebstore.google.com/
FIREFOX_ADDONS_URL=https://addons.mozilla.org/
GITHUB_SOURCE_URL=https://github.com/MariKiwi/Youtube-AI-Blocker
GITHUB_RELEASES_URL=https://github.com/MariKiwi/Youtube-AI-Blocker/releases
GOOGLE_SITE_VERIFICATION=
UMAMI_SCRIPT_URL=
UMAMI_WEBSITE_ID=
UMAMI_HOST_URL=
UMAMI_DOMAINS=
FIREFOX_ADDON_ID=youtube-ai-blocker@example.com
FIREFOX_MIN_VERSION=121.0
FIREFOX_DATA_COLLECTION_REQUIRED=websiteActivity
FIREFOX_DATA_COLLECTION_OPTIONAL=

API_IMAGE_NAME=youtube-ai-blocker-api
API_IMAGE_TAG=latest
API_PORT=3000

WEBSITE_IMAGE_NAME=youtube-ai-blocker-website
WEBSITE_IMAGE_TAG=latest
WEBSITE_PORT=8080

POSTGRES_DB=youtube_ai_blocker
POSTGRES_USER=youtube_ai_blocker
POSTGRES_PASSWORD=youtube_ai_blocker
POSTGRES_PORT=5432
POSTGRES_VOLUME_NAME=youtube-ai-blocker-postgres-data

BACKUP_DIR=./backups

CORS_ALLOWED_ORIGINS=https://www.youtube.com
WRITE_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX_REQUESTS=30
